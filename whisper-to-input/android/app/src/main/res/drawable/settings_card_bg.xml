<?xml version="1.0" encoding="utf-8"?>
<!-- Settings section card: surface color, 12dp rounded corners, subtle
     1dp divider border. Matches the Carbon Mono palette. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/carbon_surface" />
    <corners android:radius="12dp" />
    <stroke android:width="1dp" android:color="@color/carbon_divider" />
</shape>
