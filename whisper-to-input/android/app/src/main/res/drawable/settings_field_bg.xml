<?xml version="1.0" encoding="utf-8"?>
<!-- Settings EditText / Spinner background: thin divider-color bottom line
     only (floating text field style). Keeps input visually tied to the
     card's interior without adding visual weight. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    <item android:top="44dp">
        <shape android:shape="rectangle">
            <size android:height="1dp" />
            <solid android:color="@color/carbon_divider" />
        </shape>
    </item>
</layer-list>
